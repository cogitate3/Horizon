{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": ["zh", "en"],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 5
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "NYT Politics",
        "url": "https://rss.nytimes.com/services/xml/rss/nyt/Politics.xml",
        "enabled": true,
        "category": "politics"
      },
      {
        "name": "Politico",
        "url": "https://rss.politico.com/politics-news.xml",
        "enabled": true,
        "category": "politics"
      },
      {
        "name": "The Guardian US",
        "url": "https://www.theguardian.com/us-news/rss",
        "enabled": true,
        "category": "politics"
      },
      {
        "name": "CBC Top Stories",
        "url": "https://www.cbc.ca/cmlink/rss-topstories",
        "enabled": true,
        "category": "canada"
      },
      {
        "name": "Reuters World",
        "url": "https://www.reutersagency.com/feed/?taxonomy=best-sectors&post_type=best&best-sectors=world&best-sectors=world",
        "enabled": false,
        "category": "world"
      },
      {
        "name": "Ars Technica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "Semianalysis",
        "url": "https://newsletter.semianalysis.com/feed",
        "enabled": true,
        "category": "semiconductors"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "politics",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 100
        },
        {
          "subreddit": "canada",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "worldnews",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 100
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "max_items": 25,
    "category_groups": {
      "politics": { "limit": 8, "categories": ["politics", "canada", "world"] },
      "ai": { "limit": 8, "categories": ["ai-tools", "ai-news", "machine-learning"] },
      "tech": { "limit": 5, "categories": ["tech", "github-trending", "semiconductors", "linux-kernel"] }
    },
    "default_group": "other",
    "default_group_limit": 4
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {},
    "headers": ""
  }
}
